---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getProjectInfoList, getProjectDocsList } from "@utils/content-utils";

const projects = await getProjectInfoList();

// 获取每个项目的全部文档列表
const projectsWithDocs = await Promise.all(
	projects.map(async (project) => {
		const docs = await getProjectDocsList(project.name);
		return { ...project, docs };
	})
);
---

<MainGridLayout title="项目文档">
	<div class="flex flex-col gap-8">
		{projectsWithDocs.map((project, idx) => (
			<div class="card-base p-6 onload-animation" style={`animation-delay: calc(var(--content-delay) + ${idx * 100}ms)`}>
				<div class="flex items-center gap-3 mb-4">
					<Icon name="material-symbols:folder-open-outline" class="text-2xl text-[var(--primary)]" />
					<h2 class="text-xl font-bold text-90">{project.name}</h2>
					<span class="text-sm text-50 bg-[var(--license-block-bg)] px-2 py-0.5 rounded">
						{project.count} 篇文档
					</span>
				</div>
				
				<div class="flex flex-col gap-2">
					{project.docs.map((doc) => (
						<a href={`/projects/${doc.slug}/`} 
						   class="group flex items-center gap-2 py-2 px-3 rounded-lg hover:bg-[var(--btn-plain-bg-hover)] transition">
							<Icon name="material-symbols:article-outline" class="text-lg text-50 group-hover:text-[var(--primary)] transition" />
							<span class="text-75 group-hover:text-[var(--primary)] transition flex-1">{doc.data.title}</span>
							<Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] opacity-0 group-hover:opacity-100 transition" />
						</a>
					))}
				</div>
			</div>
		))}
	</div>
</MainGridLayout>
