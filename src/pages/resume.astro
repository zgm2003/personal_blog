---

import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const resumePost = await getEntry("spec", "resume");

if (!resumePost) {
	throw new Error("Resume page content not found");
}

const { Content, headings } = await render(resumePost);

const proofStats = [
	{ value: "Go", label: "Gin / GORM / Asynq", note: "企业级 Admin 后端" },
	{ value: "Py", label: "FastAPI / SQLAlchemy", note: "AI API 网关与工具服务" },
	{ value: "React", label: "Next.js / Tailwind", note: "Canvas 与 AI 工作台" },
	{ value: "4 域名", label: "线上部署矩阵", note: "前端 / 后端 / Canvas / Image" },
];

const proofLinks = [
	{
		name: "zgm2003.cn",
		url: "https://zgm2003.cn",
		desc: "admin_front_ts · Vue 3 管理前端线上站",
	},
	{
		name: "www.zgm2003.cn",
		url: "https://www.zgm2003.cn/health",
		desc: "admin_back_go · Go API / Worker / WebSocket 后端入口",
	},
	{
		name: "canvas.zgm2003.cn",
		url: "https://canvas.zgm2003.cn",
		desc: "Canvas AI · Next.js 多模态创作平台",
	},
	{
		name: "image.zgm2003.cn",
		url: "https://image.zgm2003.cn",
		desc: "chatgpt2api · Python FastAPI AI 图像网关与工作台",
	},
];

const keywords = [
	"Go",
	"Gin",
	"Python",
	"FastAPI",
	"Vue 3",
	"React",
	"Next.js",
	"TypeScript",
	"Asynq",
	"WebSocket",
	"Alipay Callback",
	"RBAC",
	"AI Agent",
	"OpenAI-Compatible",
	"Canvas AI",
	"Docker",
	"Nginx",
];
---
<MainGridLayout title="简历" description="左光明的个人简历" headings={headings} hideSidebar>
    <div class="resume-shell flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="resume-surface card-base z-10 px-5 py-5 md:px-9 md:py-7 relative w-full">
            <section class="resume-hero">
                <div class="hero-copy">
                    <div class="eyebrow">OPEN TO WORK · GO/PYTHON BACKEND · REACT/NEXT/VUE FULL STACK</div>
                    <h1>左光明</h1>
                    <p class="hero-title">Go / Python 后端 · Vue / React / Next.js 全栈 · AI 工程化</p>
                    <p class="hero-summary">
                        我不是只会写页面和单表 CRUD 的候选人。我能用 Go 做企业级 Admin 后端，用 Python FastAPI 做 AI API 网关，用 Vue 3 做管理后台，也能用 React / Next.js 做 Canvas AI 创作平台。线上已有 zgm2003.cn、www.zgm2003.cn、canvas.zgm2003.cn、image.zgm2003.cn 四个可追问部署入口。
                    </p>
                    <div class="hero-actions">
                        <a href="https://github.com/zgm2003" target="_blank" rel="noopener">看 GitHub</a>
                        <a href="https://zgm2003.cn" target="_blank" rel="noopener">Vue 管理端</a>
                        <a href="https://canvas.zgm2003.cn" target="_blank" rel="noopener">Canvas AI</a>
                        <a href="https://image.zgm2003.cn" target="_blank" rel="noopener">Image API</a>
                        <button type="button" onclick="window.print()">打印 / 存 PDF</button>
                    </div>
                    <div class="keyword-row" aria-label="技术关键词">
                        {keywords.map((keyword) => <span>{keyword}</span>)}
                    </div>
                </div>

                <div class="hero-panel" aria-label="招聘官快速判断">
                    <div class="panel-label">RECRUITER FAST SCAN</div>
                    <div class="panel-main">30 秒能看懂的工程证据</div>
                    <div class="panel-grid">
                        {proofStats.map((item) => (
                            <div class="stat-card">
                                <strong>{item.value}</strong>
                                <span>{item.label}</span>
                                <small>{item.note}</small>
                            </div>
                        ))}
                    </div>
                </div>
            </section>

            <section class="proof-board" aria-label="公开项目证据">
                <div>
                    <p class="board-kicker">LIVE DEPLOYMENTS</p>
                    <h2>不是口头包装，是能直接点开的线上项目矩阵</h2>
                </div>
                <div class="repo-grid">
                    {proofLinks.map((repo) => (
                        <a class="repo-card" href={repo.url} target="_blank" rel="noopener">
                            <strong>{repo.name}</strong>
                            <span>{repo.desc}</span>
                        </a>
                    ))}
                </div>
            </section>

            <Markdown class="resume-markdown mt-8">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<style>
	.resume-shell {
		background:
			radial-gradient(circle at 18% 12%, rgba(89, 255, 198, 0.18), transparent 28rem),
			radial-gradient(circle at 82% 5%, rgba(255, 191, 87, 0.16), transparent 24rem),
			linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
	}

	.resume-surface {
		overflow: hidden;
	}

	.resume-surface::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
		background-size: 42px 42px;
		mask-image: linear-gradient(to bottom, black, transparent 42rem);
	}

	.resume-hero,
	.proof-board,
	.resume-markdown {
		position: relative;
		z-index: 1;
	}

	.resume-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.16fr) minmax(18rem, 0.84fr);
		gap: 1.25rem;
		align-items: stretch;
		padding: 1.15rem;
		border: 1px solid rgba(255,255,255,0.12);
		border-radius: 1.75rem;
		background:
			linear-gradient(135deg, rgba(18, 24, 38, 0.86), rgba(10, 13, 23, 0.76)),
			radial-gradient(circle at top right, rgba(90, 255, 198, 0.2), transparent 18rem);
		box-shadow: 0 30px 90px rgba(0,0,0,0.28);
	}

	.hero-copy {
		padding: 1.2rem;
	}

	.eyebrow,
	.board-kicker,
	.panel-label {
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		font-weight: 800;
		color: oklch(0.82 0.16 var(--hue));
		text-transform: uppercase;
	}

	.hero-copy h1 {
		margin: 0.42rem 0 0;
		font-size: clamp(3rem, 8vw, 6.5rem);
		line-height: 0.92;
		letter-spacing: -0.08em;
		font-weight: 950;
		color: rgba(255,255,255,0.96);
	}

	.hero-title {
		margin: 0.9rem 0 0;
		font-size: clamp(1.08rem, 2vw, 1.55rem);
		font-weight: 850;
		color: rgba(255,255,255,0.92);
	}

	.hero-summary {
		max-width: 54rem;
		margin: 1rem 0 0;
		font-size: 1rem;
		line-height: 1.9;
		color: rgba(255,255,255,0.76);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.3rem;
	}

	.hero-actions a,
	.hero-actions button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.65rem;
		padding: 0 1rem;
		border-radius: 999px;
		color: rgba(255,255,255,0.92);
		font: inherit;
		font-weight: 800;
		background: rgba(255,255,255,0.1);
		border: 1px solid rgba(255,255,255,0.16);
		backdrop-filter: blur(12px);
		cursor: pointer;
		transition: transform .18s ease, background .18s ease, border-color .18s ease;
	}

	.hero-actions a:first-child {
		background: linear-gradient(135deg, oklch(0.72 0.18 var(--hue)), oklch(0.72 0.14 170));
		color: #07100d;
	}

	.hero-actions a:hover,
	.hero-actions button:hover {
		transform: translateY(-2px);
		background: rgba(255,255,255,0.16);
		border-color: rgba(255,255,255,0.32);
	}

	.keyword-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1.2rem;
	}

	.keyword-row span {
		font-size: 0.78rem;
		font-weight: 750;
		color: rgba(255,255,255,0.7);
		padding: 0.36rem 0.62rem;
		border-radius: 999px;
		border: 1px solid rgba(255,255,255,0.12);
		background: rgba(255,255,255,0.055);
	}

	.hero-panel {
		padding: 1.15rem;
		border-radius: 1.35rem;
		background:
			linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.055));
		border: 1px solid rgba(255,255,255,0.16);
	}

	.panel-main {
		margin-top: 0.42rem;
		font-size: 1.18rem;
		font-weight: 900;
		color: rgba(255,255,255,0.92);
	}

	.panel-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.stat-card {
		min-height: 8rem;
		padding: 1rem;
		border-radius: 1.1rem;
		background: rgba(4, 8, 15, 0.42);
		border: 1px solid rgba(255,255,255,0.11);
	}

	.stat-card strong {
		display: block;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1;
		color: rgba(255,255,255,0.98);
		letter-spacing: -0.06em;
	}

	.stat-card span,
	.stat-card small {
		display: block;
		margin-top: 0.42rem;
	}

	.stat-card span {
		font-weight: 850;
		color: rgba(255,255,255,0.84);
	}

	.stat-card small {
		color: rgba(255,255,255,0.52);
		line-height: 1.45;
	}

	.proof-board {
		display: grid;
		grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
		gap: 1rem;
		margin-top: 1.1rem;
		padding: 1.15rem;
		color: #0b1220;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1.5rem;
		background:
			radial-gradient(circle at 12% 10%, rgba(78, 195, 255, 0.16), transparent 22rem),
			linear-gradient(135deg, rgba(255,255,255,0.98), rgba(239,246,255,0.92));
		box-shadow: 0 24px 70px rgba(15,23,42,0.08);
		overflow: hidden;
	}

	.proof-board h2 {
		margin: 0.38rem 0 0;
		font-size: clamp(1.35rem, 3vw, 2.15rem);
		line-height: 1.15;
		letter-spacing: -0.04em;
		color: #050b18;
		text-wrap: balance;
	}

	.repo-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.7rem;
	}

	.repo-card {
		display: block;
		padding: 0.9rem;
		border-radius: 1rem;
		text-decoration: none;
		border: 1px solid rgba(15,23,42,0.12);
		background:
			linear-gradient(135deg, rgba(17,24,39,0.96), rgba(30,41,59,0.92)),
			radial-gradient(circle at 85% 0%, rgba(80, 220, 190, 0.22), transparent 14rem);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 16px 34px rgba(15,23,42,0.12);
		transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
	}

	.repo-card:hover {
		transform: translateY(-2px);
		border-color: oklch(0.72 0.16 var(--hue));
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 22px 44px rgba(15,23,42,0.18);
	}

	.repo-card strong,
	.repo-card span {
		display: block;
	}

	.repo-card strong {
		color: rgba(255,255,255,0.92);
		font-weight: 900;
	}

	.repo-card span {
		margin-top: 0.34rem;
		color: rgba(255,255,255,0.6);
		font-size: 0.86rem;
		line-height: 1.55;
	}

	:global(.resume-markdown table) {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		white-space: normal;
	}

	:global(.resume-markdown th),
	:global(.resume-markdown td) {
		vertical-align: top;
		overflow-wrap: anywhere;
		word-break: normal;
	}

	:global(.resume-markdown th:first-child),
	:global(.resume-markdown td:first-child) {
		width: 9.5rem;
	}

	:global(.resume-markdown th:nth-child(2)),
	:global(.resume-markdown td:nth-child(2)) {
		width: 13.5rem;
	}

	:global(.resume-markdown blockquote) {
		border-left-color: oklch(0.72 0.16 var(--hue));
		background: rgba(255,255,255,0.035);
		border-radius: 0.9rem;
		padding: 0.75rem 1rem;
	}

	@media (max-width: 980px) {
		.resume-hero,
		.proof-board {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.panel-grid,
		.repo-grid {
			grid-template-columns: 1fr;
		}

		.hero-copy,
		.hero-panel,
		.proof-board {
			padding: 0.95rem;
		}

		:global(.resume-markdown table),
		:global(.resume-markdown tbody),
		:global(.resume-markdown tr),
		:global(.resume-markdown td) {
			display: block;
			width: 100%;
		}

		:global(.resume-markdown td:first-child),
		:global(.resume-markdown td:nth-child(2)),
		:global(.resume-markdown td:nth-child(3)) {
			width: 100%;
		}

		:global(.resume-markdown thead) {
			display: none;
		}

		:global(.resume-markdown tr) {
			margin: 0.85rem 0;
			padding: 0.85rem;
			border: 1px solid rgba(15,23,42,0.08);
			border-radius: 1rem;
			background: linear-gradient(135deg, rgba(255,255,255,0.92), rgba(248,250,252,0.82));
			box-shadow: 0 14px 34px rgba(15,23,42,0.07);
		}

		:global(.resume-markdown td) {
			padding: 0.28rem 0;
			border: 0;
		}

		:global(.resume-markdown td:first-child) {
			font-size: 1.02rem;
			font-weight: 850;
		}

		:global(.resume-markdown td:first-child a) {
			text-decoration-thickness: 2px;
			text-underline-offset: 3px;
		}
	}

	@media print {
		.resume-shell {
			background: white;
		}

		.resume-hero,
		.proof-board {
			box-shadow: none;
			break-inside: avoid;
		}

		.hero-actions,
		.keyword-row {
			display: none;
		}
	}
</style>
