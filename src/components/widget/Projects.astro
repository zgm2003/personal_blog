---
import { getProjectInfoList } from "@utils/content-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

const projects = await getProjectInfoList();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name="项目文档" id="projects" isCollapsed={false} class={className} style={style}>
	{projects.map((p) =>
		<ButtonLink
			url={`/projects/`}
			badge={String(p.count)}
			label={`查看 ${p.name} 项目的所有文档`}
		>
			{p.name}
		</ButtonLink>
	)}
</WidgetLayout>
